{
  "buildCommand": "npx vite build && npx tsx script/build-premium.ts && cp dist/public/premium/index.html dist/public/index.html",
  "outputDirectory": "dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://api.leadawaker.com/api/:path*" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/terms-of-service", "destination": "/premium/terms.html" },
    { "source": "/privacy-policy", "destination": "/premium/privacy.html" },
    { "source": "/(.*)", "destination": "/app.html" }
  ]
}
